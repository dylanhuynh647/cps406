FROM node:20-alpine AS frontend

# Set work directory
WORKDIR /app

# Copy frontend code
COPY package.json package-lock.json* ./
COPY src/ ./src/
COPY index.html ./
COPY tsconfig.json tsconfig.node.json ./
COPY tailwind.config.js postcss.config.js ./

# Install dependencies
RUN npm install

# Build frontend
RUN npm run build

# Expose frontend port
EXPOSE 5173

# Start frontend
CMD ["npm", "run", "dev"]
